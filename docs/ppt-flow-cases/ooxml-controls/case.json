    "requiredDeckJsonSubstrings": [
      "\"master\"",
      "\"placeholders\"",
      "\"transition\"",
      "\"xAxis\"",
      "\"yAxis\"",
      "\"secondaryYAxis\"",
      "\"legend\"",
      "\"plotArea\"",
      "\"marker\"",
      "\"cellPadding\"",
      "\"borders\"",
      "\"tableStyleId\"",
      "\"straightConnector\"",
      "\"tailEnd\"",
      "#slide5"
    ],
    "requiredPptxXmlSubstrings": [
      "p:transition",
      "p:ph type=\"title\"",
      "straightConnector1",
      "a:tailEnd type=\"triangle\"",
      "ppaction://hlinksldjump",
      "c:legendPos val=\"r\"",
      "c:majorGridlines",
      "c:manualLayout"
    ],
    "requiredPptxContentSubstrings": [
      "指标",
      "准备度",
      "质量",
      "附录"
    ]
  }
