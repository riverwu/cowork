{
  "id": "ooxml-controls",
  "desktopDebugLog": true,
  "expected": {
    "requiredTools": ["read_file", "write_file", "shell", "init_deck", "validate_slide", "validate_manifest", "compose"],
    "forbiddenTools": ["create_deck", "replace_slide", "insert_slide", "delete_slide", "patch_deck", "validate_render"],
