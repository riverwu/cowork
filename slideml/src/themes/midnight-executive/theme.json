{
  "name": "midnight-executive",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Midnight Executive",
  "description": "Premium executive theme — deep navy canvas with ice-blue muted text and an amber accent. Reads like a board pack.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "1E2761",
    "bg-card": "2A3580",
    "brand-primary": "8FA6FF",
    "brand-deep": "5566D2",
    "text-strong": "F5F8FF",
    "text-muted": "CADCFC",
    "accent": "FFB400",
    "divider": "4554A8",
    "font-latin": [
      "Helvetica Neue",
      "Inter",
      "Avenir Next",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Source Han Sans CN",
      "Microsoft YaHei",
      "Noto Sans CJK SC",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "SF Mono",
      "JetBrains Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "board / executives",
      "investors (premium / private)",
      "C-suite",
      "M&A / bank reviewers"
    ],
    "industries": [
      "finance",
      "private equity",
      "venture capital",
      "premium SaaS",
      "enterprise software"
    ],
    "moods": [
      "premium",
      "serious",
      "trustworthy",
      "high-stakes",
      "polished"
    ],
    "antiPatterns": [
      "consumer / playful",
      "scrappy startup pitch",
      "internal eng review",
      "casual workshop"
    ]
  },
  "style": {
    "titleAccentRule": true,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "◆",
      "color": "accent"
    },
    "imagery": {
      "guidance": "Premium / aspirational. Deep navy background dominant; ice-blue and amber as highlights. Subjects: night skylines from a high floor, polished marble lobbies, modernist boardrooms, abstract financial geometry, brushed metal, single-source amber accent lighting. Lighting: low-key, cinematic, single-source warm highlight on cool background. Avoid: daytime / harsh light, cartoon, bright primary colors, casual lifestyle photography, anything that reads as 'startup hustle'.",
      "palette": [
        "#1E2761",
        "#8FA6FF",
        "#FFB400",
        "#0F1340"
      ],
      "preferredStyles": [
        "cinematic low-key",
        "architectural night photography",
        "luxury product photography",
        "abstract minimalist"
      ],
      "avoid": [
        "daytime / bright",
        "cartoon",
        "casual / startup vibe",
        "primary colors",
        "white backgrounds"
      ]
    },
    "voice": {
      "tone": "Confident, decisive, no hedging. Numbers carry the argument; adjectives are sparse and earned.",
      "avoid": [
        "hedge words (perhaps, possibly, might)",
        "exclamation marks",
        "marketing superlatives"
      ]
    },
    "surface": {
      "cornerRadius": 0.04,
      "elevation": "shadow",
      "accentStripe": {
        "position": "left",
        "widthCm": 0.18,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "4ADE80",
      "negative": "F87171",
      "warning": "FACC15",
      "info": "60A5FA",
      "neutral": "94A3B8"
    },
    "dataviz": {
      "categorical": [
        "60A5FA",
        "4ADE80",
        "F87171",
        "FACC15",
        "C084FC",
        "38BDF8"
      ],
      "sequential": {
        "from": "1E293B",
        "to": "60A5FA"
      },
      "diverging": {
        "negative": "F87171",
        "mid": "475569",
        "positive": "4ADE80"
      }
    },
    "typography": {
      "baseHalfPt": 28,
      "ratio": 1.25,
      "italicCjk": false,
      "numerals": "tabular",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 2
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "upper",
          "trackingHalfPt": 4
        }
      }
    },
    "numbering": {
      "style": "circled"
    },
    "chips": {
      "up": {
        "glyph": "▲",
        "color": "4ADE80"
      },
      "down": {
        "glyph": "▼",
        "color": "F87171"
      },
      "ok": {
        "glyph": "✓",
        "color": "4ADE80"
      },
      "warn": {
        "glyph": "⚠",
        "color": "FACC15"
      },
      "bad": {
        "glyph": "✗",
        "color": "F87171"
      }
    },
    "table": {
      "headerFill": "brand-deep",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "accent"
    },
    "image": {
      "defaultClip": "rounded"
    }
  },
  "oxml": {
    "clrScheme": {
