        "4F8C3F",
        "7BA05B",
        "4A7C8C",
        "C88A2E",
        "A04444",
        "6B5B95"
      ],
      "sequential": {
        "from": "F0EAD6",
        "to": "2D4A2A"
      },
      "diverging": {
        "negative": "A04444",
        "mid": "E0D9C4",
        "positive": "4F8C3F"
      }
    },
    "typography": {
      "baseHalfPt": 28,
      "ratio": 1.2,
      "italicCjk": false,
      "numerals": "proportional",
      "roles": {
