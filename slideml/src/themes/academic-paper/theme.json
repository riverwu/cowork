{
  "name": "academic-paper",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Academic Paper",
  "description": "Scholarly research / conference theme — restrained serif typography, AAA-grade contrast, tabular numerals, conservative dataviz. Designed for thesis defenses, conference talks, peer-reviewed-paper presentations, and grant pitches that should read substance-first.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "FFFFFF",
    "bg-card": "F7F7F5",
    "brand-primary": "8B0000",
    "brand-deep": "2F2F2F",
    "text-strong": "111111",
    "text-muted": "4A4A4A",
    "accent": "6B5B3A",
    "divider": "CFCFCF",
    "font-latin": [
      "EB Garamond",
      "Garamond",
      "Adobe Garamond Pro",
      "Georgia",
      "Times New Roman",
      "serif"
    ],
    "font-cjk": [
      "Source Han Serif SC",
      "Songti SC",
      "STSong",
      "SimSun",
      "Noto Serif CJK SC",
      "serif"
    ],
    "font-mono": [
      "Latin Modern Mono",
      "JetBrains Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "conference attendees",
      "dissertation committees",
      "peer reviewers",
      "grant panels",
      "academic seminars"
    ],
    "industries": [
      "academia",
      "research institutes",
      "university faculty",
      "public-policy think tanks",
      "scientific publishing"
    ],
    "moods": [
      "scholarly",
      "restrained",
      "rigorous",
      "timeless",
      "substance-first"
    ],
    "antiPatterns": [
      "marketing pitches",
      "startup demo days",
      "consumer brands",
      "sales decks"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "AAA",
    "bullets": {
      "glyph": "·",
      "color": "text-strong",
      "level1": "◦",
      "level2": "·"
    },
    "fontSizes": {
      "xs": 10,
      "sm": 12,
      "base": 14,
      "lg": 17,
      "xl": 22,
      "display": 36,
      "hero": 64
    },
    "surface": {
      "cornerRadius": 0,
      "elevation": "flat",
      "accentStripe": {
        "position": "none",
        "widthCm": 0.06,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "2F6B2F",
      "negative": "8B0000",
      "warning": "8B6914",
      "info": "24507A",
      "neutral": "4A4A4A"
    },
    "dataviz": {
      "categorical": [
        "1F4E79",
        "8B0000",
        "2F6B2F",
        "8B6914"
      ],
      "sequential": {
        "from": "F2F2F2",
        "to": "1F4E79"
      },
      "diverging": {
        "negative": "8B0000",
        "mid": "F0F0EE",
        "positive": "2F6B2F"
      }
    },
    "typography": {
      "baseHalfPt": 26,
      "ratio": 1.2,
      "italicCjk": false,
      "numerals": "tabular",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "smallCaps",
          "trackingHalfPt": 6
        }
      }
    },
    "numbering": {
      "style": "roman"
    },
    "chips": {
      "up": {
        "glyph": "▲"
      },
      "down": {
        "glyph": "▼"
      },
      "flat": {
        "glyph": "—"
      },
      "ok": {
        "glyph": "✓"
      },
      "warn": {
        "glyph": "!"
      },
      "bad": {
        "glyph": "✗"
      }
    },
    "image": {
      "defaultClip": "rect"
    },
    "table": {
      "headerFill": "brand-deep",
      "rowStripe": false,
      "borderStyle": "full",
      "firstColEmphasis": "bold"
    },
    "imagery": {
      "guidance": "Restrained academic figures: data visualisation, archival imagery, line drawings, monochrome photography, hand-drawn diagrams. Avoid commercial stock photography, lens flare, gradients, decorative noise. Compositions should have clear hierarchy and serve a specific argument.",
      "palette": [
        "#FFFFFF",
        "#111111",
        "#8B0000",
        "#1F4E79",
        "#2F6B2F"
      ],
      "avoid": [
        "stock photography",
        "gradients",
        "color grading",
        "lens flare",
        "vibrant saturated colors",
        "decorative imagery"
      ],
      "preferredStyles": [
        "data visualization",
        "line drawing",
        "monochrome photography",
        "archival photo",
        "technical diagram",
        "hand-drawn figure"
      ]
    },
    "voice": {
      "tone": "precise, evidence-led, third-person, citation-aware",
      "avoid": [
        "marketing language",
        "superlatives",
        "exclamation points",
        "hyperbole"
      ]
    }
  },
