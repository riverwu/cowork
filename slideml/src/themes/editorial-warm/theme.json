{
  "name": "editorial-warm",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Editorial Warm",
  "description": "Editorial / consulting deck — cream canvas, deep warm grays, rust accent. Serif headings, sans body. Print-friendly.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "FBF7F0",
    "bg-card": "FFFFFF",
    "brand-primary": "C0432D",
    "brand-deep": "8C2E1B",
    "text-strong": "2C2620",
    "text-muted": "7A6F62",
    "accent": "A88859",
    "divider": "E5DCC9",
    "font-latin": [
      "Source Sans Pro",
      "Helvetica Neue",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Microsoft YaHei",
      "Source Han Sans CN",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "consultants",
      "investors (narrative-style)",
      "policy / think-tank readers",
      "long-form readers"
    ],
    "industries": [
      "consulting",
      "wealth / private banking",
      "publishing",
      "non-profit",
      "policy",
      "professional services"
    ],
    "moods": [
      "editorial",
      "warm",
      "classical",
      "considered",
      "print-friendly"
    ],
    "antiPatterns": [
      "dashboards",
      "engineering / code-heavy decks",
      "high-density data slides",
      "tech keynotes"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "warn",
    "imagery": {
      "guidance": "Editorial photography or warm-tone illustration. Cream paper background feel, with rust / terracotta / muted-gold accents. Subjects: hands writing, books, neutral office environments, abstract paper textures, warm portraits, architectural details. Lighting: soft natural daylight, golden-hour warmth. Composition: classical, considered, plenty of negative space. Avoid: cool blues, neon, cyberpunk, screens / monitors, harsh strobe lighting.",
      "palette": [
        "#FBF7F0",
        "#C0432D",
        "#A88859",
        "#2C2620"
      ],
      "preferredStyles": [
        "editorial photography",
        "natural light",
        "soft warm tones",
        "watercolor accent illustration",
        "documentary"
      ],
      "avoid": [
        "cool blue",
        "neon",
        "screens / monitors",
        "tech / cyber aesthetic",
        "harsh fluorescent lighting"
      ]
    },
    "voice": {
      "tone": "Considered, narrative, slightly literary. Full sentences over bullet fragments. Avoid jargon.",
      "avoid": [
        "bullet-point shorthand for ideas that deserve a sentence",
        "tech buzzwords"
      ]
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
      "accent1": "brand-primary",
      "accent2": "brand-deep",
      "accent3": "accent",
      "accent4": "text-muted",
      "accent5": "divider",
      "accent6": "bg-card",
      "hlink": "brand-primary",
      "folHlink": "brand-deep"
    },
    "fontScheme": {
      "majorLatin": "Source Serif Pro",
      "minorLatin": "Source Sans Pro"
    }
  },
  "layouts": [
    {
      "name": "cover",
      "module": "layouts/cover.js",
      "thumbnail": "thumbnails/cover.png"
    },
    {
      "name": "agenda",
      "module": "layouts/agenda.js",
      "thumbnail": "thumbnails/agenda.png"
    },
    {
      "name": "stat-grid-3",
      "module": "layouts/stat-grid-3.js",
      "thumbnail": "thumbnails/stat-grid-3.png"
    },
    {
      "name": "chart-with-takeaway",
      "module": "layouts/chart-with-takeaway.js",
      "thumbnail": "thumbnails/chart-with-takeaway.png"
    },
    {
      "name": "bullet-with-image",
      "module": "layouts/bullet-with-image.js",
      "thumbnail": "thumbnails/bullet-with-image.png"
    },
    {
      "name": "closing",
      "module": "layouts/closing.js",
      "thumbnail": "thumbnails/closing.png"
    },
    {
      "name": "split-2",
      "module": "layouts/split-2.js",
      "thumbnail": "thumbnails/split-2.png"
    },
    {
      "name": "split-3-horizontal",
      "module": "layouts/split-3-horizontal.js",
      "thumbnail": "thumbnails/split-3-horizontal.png"
    },
    {
      "name": "split-3-vertical",
      "module": "layouts/split-3-vertical.js",
      "thumbnail": "thumbnails/split-3-vertical.png"
    }
  ],
  "chrome": [
    "page-number"
  ]
}
