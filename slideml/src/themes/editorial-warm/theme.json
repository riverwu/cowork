{
  "name": "editorial-warm",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Editorial Warm",
  "description": "Editorial / consulting deck — cream canvas, deep warm grays, rust accent. Serif headings, sans body. Print-friendly.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "FBF7F0",
    "bg-card": "FFFFFF",
    "brand-primary": "C0432D",
    "brand-deep": "8C2E1B",
    "text-strong": "2C2620",
    "text-muted": "7A6F62",
    "accent": "A88859",
    "divider": "E5DCC9",
    "font-latin": [
      "Source Sans 3",
      "Source Sans Pro",
      "Helvetica Neue",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "Source Han Serif SC",
      "PingFang SC",
      "Microsoft YaHei",
      "Source Han Sans CN",
      "Noto Sans CJK SC",
      "Noto Sans SC",
      "serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Iosevka",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "consultants",
      "investors (narrative-style)",
      "policy / think-tank readers",
      "long-form readers"
    ],
    "industries": [
      "consulting",
      "wealth / private banking",
      "publishing",
      "non-profit",
      "policy",
      "professional services"
    ],
    "moods": [
      "editorial",
      "warm",
      "classical",
      "considered",
      "print-friendly"
    ],
    "antiPatterns": [
      "dashboards",
      "engineering / code-heavy decks",
      "high-density data slides",
      "tech keynotes"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "—",
      "color": "brand-primary"
    },
    "imagery": {
      "guidance": "Editorial photography or warm-tone illustration. Cream paper background feel, with rust / terracotta / muted-gold accents. Subjects: hands writing, books, neutral office environments, abstract paper textures, warm portraits, architectural details. Lighting: soft natural daylight, golden-hour warmth. Composition: classical, considered, plenty of negative space. Avoid: cool blues, neon, cyberpunk, screens / monitors, harsh strobe lighting.",
      "palette": [
        "#FBF7F0",
        "#C0432D",
        "#A88859",
        "#2C2620"
      ],
      "preferredStyles": [
        "editorial photography",
        "natural light",
        "soft warm tones",
        "watercolor accent illustration",
        "documentary"
      ],
      "avoid": [
        "cool blue",
        "neon",
        "screens / monitors",
        "tech / cyber aesthetic",
        "harsh fluorescent lighting"
      ]
    },
    "voice": {
      "tone": "Considered, narrative, slightly literary. Full sentences over bullet fragments. Avoid jargon.",
      "avoid": [
        "bullet-point shorthand for ideas that deserve a sentence",
        "tech buzzwords"
      ]
    },
    "surface": {
      "cornerRadius": 0.025,
      "elevation": "hairline",
      "accentStripe": {
        "position": "left",
        "widthCm": 0.14,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "6B8E5C",
      "negative": "B85542",
      "warning": "BC8031",
      "info": "7A8AB0",
      "neutral": "8A7460"
    },
    "dataviz": {
      "categorical": [
        "B85542",
        "CC8D3A",
        "6B8E5C",
        "7A8AB0",
        "A26988",
        "4F8F8F"
      ],
      "sequential": {
        "from": "FAF1E5",
        "to": "B85542"
      },
      "diverging": {
        "negative": "B85542",
        "mid": "F0E5D2",
        "positive": "6B8E5C"
      }
    },
    "typography": {
      "baseHalfPt": 26,
      "ratio": 1.25,
      "italicCjk": false,
      "numerals": "proportional",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "smallCaps",
          "trackingHalfPt": 6
        }
      }
    },
    "numbering": {
      "style": "padded"
    },
    "table": {
      "headerFill": "brand-deep",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "accent"
    },
    "image": {
      "defaultClip": "rect"
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
