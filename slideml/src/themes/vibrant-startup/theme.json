{
  "name": "vibrant-startup",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Vibrant Startup",
  "description": "Modern SaaS pitch / launch theme — bright purple-coral-teal palette, generously rounded cards with soft shadows, sans-serif modular scale, circled numerals. Optimised for fund-raising decks, product launches, marketing keynote slides where the deck has to read confident and contemporary.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "FBFAFE",
    "bg-card": "FFFFFF",
    "brand-primary": "7C3AED",
    "brand-deep": "4C1D95",
    "text-strong": "1E1B2E",
    "text-muted": "6B6483",
    "accent": "EC4899",
    "divider": "E5E1F2",
    "font-latin": [
      "Inter",
      "SF Pro Display",
      "Segoe UI",
      "Helvetica Neue",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Source Han Sans SC",
      "Noto Sans CJK SC",
      "Microsoft YaHei",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Fira Code",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "venture investors",
      "product launch attendees",
      "growth marketing",
      "startup demo days"
    ],
    "industries": [
      "saas",
      "consumer tech",
      "fintech",
      "ecommerce",
      "dev tools"
    ],
    "moods": [
      "confident",
      "contemporary",
      "energetic",
      "optimistic",
      "playful"
    ],
    "antiPatterns": [
      "enterprise board reports",
      "academic / scholarly",
      "heritage brands",
      "print-feel keynote"
    ]
  },
  "style": {
    "titleAccentRule": true,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "◆",
      "color": "brand-primary",
      "level1": "◇",
      "level2": "·"
    },
    "fontSizes": {
      "xs": 10,
      "sm": 12,
      "base": 14,
      "lg": 18,
      "xl": 26,
      "display": 56,
      "hero": 110
    },
    "surface": {
      "cornerRadius": 0.08,
      "elevation": "shadow",
      "accentStripe": {
        "position": "left",
        "widthCm": 0.18,
        "color": "accent"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "0EA271",
      "negative": "EF4444",
      "warning": "C47E08",
      "info": "3B82F6",
      "neutral": "6B7280"
    },
    "dataviz": {
      "categorical": [
        "7C3AED",
        "EC4899",
        "10B981",
        "F59E0B",
        "06B6D4",
        "64748B"
      ],
      "sequential": {
        "from": "F3F0FF",
        "to": "4C1D95"
      },
      "diverging": {
        "negative": "EF4444",
        "mid": "F5F3FB",
        "positive": "10B981"
      }
    },
    "typography": {
      "baseHalfPt": 28,
      "ratio": 1.333,
      "italicCjk": false,
      "numerals": "proportional",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "upper",
          "trackingHalfPt": 6
        }
      }
    },
    "numbering": {
      "style": "circled"
    },
    "chips": {
      "up": {
        "glyph": "↑",
        "color": "10B981"
      },
      "down": {
        "glyph": "↓",
        "color": "EF4444"
      },
      "ok": {
        "glyph": "✓",
        "color": "10B981"
      },
      "warn": {
        "glyph": "⚠",
        "color": "F59E0B"
      },
      "bad": {
        "glyph": "✗",
        "color": "EF4444"
      },
      "highlight": {
        "glyph": "★",
        "color": "EC4899"
      }
    },
    "image": {
      "defaultClip": "rounded"
    },
    "table": {
      "headerFill": "brand-primary",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "bold"
    },
    "imagery": {
      "guidance": "Modern, vibrant tech illustrations or product mockups. Bold gradients (purple→pink→teal), abstract geometric shapes, isometric devices, photo-real product shots on light backgrounds with subtle drop shadows. Lighting: bright, optimistic, slightly futuristic. Avoid: corporate stock photography, somber palettes, anything dated or heritage.",
      "palette": [
        "#7C3AED",
        "#EC4899",
        "#10B981",
        "#F59E0B",
        "#FBFAFE"
      ],
      "avoid": [
        "corporate stock",
        "dated stock",
        "sepia",
        "dark moody",
        "navy + grey"
      ],
      "preferredStyles": [
        "gradient illustration",
        "isometric",
        "product mockup",
        "abstract geometric",
        "flat illustration with soft shadows"
      ]
    },
    "voice": {
      "tone": "confident, momentum-led, second-person (\"you can\"), forward-looking",
      "avoid": [
        "hedging",
        "academic qualifiers",
        "passive voice"
      ]
    }
  },
