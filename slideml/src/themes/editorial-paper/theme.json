{
  "name": "editorial-paper",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Editorial Paper",
  "description": "Magazine-style theme — refined paper palette, serif headlines, asymmetric margins, hairline rules. Designed for long-form essays, founder letters, design-led keynote pieces, and published reports that should feel like print.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "F4EFE3",
    "bg-card": "FFFFFF",
    "brand-primary": "9B2D20",
    "brand-deep": "2B1810",
    "text-strong": "1A1410",
    "text-muted": "6F635A",
    "accent": "C49B5C",
    "divider": "D8CFBF",
    "semantic-up": "5C7A4A",
    "semantic-down": "9B2D20",
    "semantic-warn": "B8821C",
    "semantic-bad": "9B2D20",
    "font-latin": [
      "Source Serif 4",
      "Source Serif Pro",
      "Crimson Pro",
      "Georgia",
      "Times New Roman",
      "serif"
    ],
    "font-cjk": [
      "Source Han Serif SC",
      "Songti SC",
      "STSong",
      "SimSun",
      "Noto Serif CJK SC",
      "serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Iosevka",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "magazine readers",
      "long-form readers",
      "design / culture",
      "founder-letter recipients",
      "annual-report committees"
    ],
    "industries": [
      "publishing",
      "design / media",
      "fashion / lifestyle brands",
      "non-profit annual reports",
      "cultural institutions"
    ],
    "moods": [
      "refined",
      "literary",
      "considered",
      "print-feel",
      "warm but disciplined"
    ],
    "antiPatterns": [
      "engineering / data-heavy decks",
      "fast-paced sales decks",
      "dashboards",
      "code walkthroughs",
      "anything that needs to read at 6m projection distance"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "—",
      "color": "brand-primary"
    },
    "fontSizes": {
      "xs": 9,
      "sm": 11,
      "base": 13,
      "lg": 17,
      "xl": 26,
      "display": 56,
      "hero": 110
    },
    "imagery": {
      "guidance": "Editorial print photography — natural light, paper textures, hands, archival objects, classical portraits, fine-art still lifes. Warm cream / terracotta / muted-gold palette. Composition is deliberate and asymmetric with generous negative space. Lighting is soft daylight or golden hour. Avoid: tech / screens, neon, cool blues, harsh studio strobe, lifestyle stock photography, anything with obvious colour grading.",
      "palette": [
        "#F4EFE3",
        "#9B2D20",
        "#C49B5C",
        "#2B1810"
      ],
      "preferredStyles": [
        "editorial photography",
        "natural light",
        "fine-art still life",
        "watercolor accent",
        "letterpress / risograph",
        "documentary"
      ],
      "avoid": [
        "screens / monitors",
        "neon",
        "cool blue / cyber",
        "stock-photo sheen",
        "harsh strobe",
        "saturated marketing illustration"
      ]
    },
    "voice": {
      "tone": "Considered, literary, slightly formal. Full sentences over bullets. Reads aloud. Uses semicolons. Avoids buzzwords, exclamation marks, and any phrase you'd hear in a sales meeting.",
      "avoid": [
        "buzzwords",
        "exclamation marks",
        "tech jargon",
        "bullet shorthand for ideas that deserve a sentence",
        "sales-deck superlatives ('industry-leading', 'best-in-class')"
      ]
    },
    "surface": {
      "cornerRadius": 0.02,
      "elevation": "hairline",
      "accentStripe": {
        "position": "top",
        "widthCm": 0.1,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "5C7A4A",
      "negative": "9B2D20",
      "warning": "A27219",
      "info": "6B7BA8",
      "neutral": "6F635A"
    },
    "dataviz": {
      "categorical": [
        "9B2D20",
        "6B7BA8",
        "5C7A4A",
        "B8821C",
        "3F3A4F",
        "4A8C8C"
      ],
      "sequential": {
        "from": "F4EFE3",
        "to": "9B2D20"
      },
      "diverging": {
        "negative": "9B2D20",
        "mid": "EAE3D2",
        "positive": "5C7A4A"
      }
    },
    "typography": {
      "baseHalfPt": 26,
      "ratio": 1.25,
      "italicCjk": false,
      "numerals": "proportional",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "smallCaps",
          "trackingHalfPt": 8
        }
      }
    },
    "numbering": {
      "style": "roman"
    },
    "table": {
      "headerFill": "brand-deep",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "bold"
    },
    "image": {
      "defaultClip": "rect",
      "treatment": "sepia"
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
      "accent1": "brand-primary",
      "accent2": "brand-deep",
      "accent3": "accent",
      "accent4": "text-muted",
      "accent5": "divider",
      "accent6": "bg-card",
      "hlink": "brand-primary",
      "folHlink": "brand-deep"
    },
    "fontScheme": {
      "majorLatin": "Source Serif 4",
      "minorLatin": "Source Serif Pro"
    }
  },
