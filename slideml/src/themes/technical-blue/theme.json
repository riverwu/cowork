{
  "name": "technical-blue",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Technical Blue",
  "description": "Engineering / data deck — deep navy canvas with cyan accents and high information density.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "0B1B2A",
    "bg-card": "14304A",
    "brand-primary": "38BDF8",
    "brand-deep": "0369A1",
    "text-strong": "F1F5F9",
    "text-muted": "94A3B8",
    "accent": "F472B6",
    "divider": "1E3A5F",
    "font-latin": [
      "Inter",
      "IBM Plex Sans",
      "Helvetica Neue",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Source Han Sans CN",
      "Microsoft YaHei",
      "Noto Sans CJK SC",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Fira Code",
      "SF Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ],
    "semantic-up": "4ADE80",
    "semantic-down": "F87171",
    "semantic-warn": "FBBF24",
    "semantic-bad": "F87171"
  },
  "meta": {
    "audiences": [
      "engineers",
      "data teams",
      "internal technical reviewers"
    ],
    "industries": [
      "software",
      "platform engineering",
      "infrastructure",
      "data analytics",
      "DevOps",
      "fintech"
    ],
    "moods": [
      "serious",
      "precise",
      "data-dense",
      "high-information"
    ],
    "antiPatterns": [
      "consumer marketing",
      "wellness / lifestyle",
      "playful presentations",
      "elementary education"
    ]
  },
  "style": {
    "titleAccentRule": true,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "›",
      "color": "brand-primary"
    },
    "imagery": {
      "guidance": "Photographic or rendered, deep-tone, high-contrast. Cool blue / navy / cyan palette dominant. Subjects: server rooms, network diagrams, code on screens, geometric data visualizations, abstract circuitry, satellite/aerial views. Lighting: cinematic low-key with cyan accent highlights. Avoid: bright pastels, cartoonish illustrations, white backgrounds, hand-drawn marketing illustration styles, lifestyle photography.",
      "palette": [
        "#0B1B2A",
        "#3CC2FF",
        "#1078B5",
        "#F5F9FC"
      ],
      "preferredStyles": [
        "photographic",
        "cinematic",
        "low-key lit",
        "isometric technical illustration",
        "data-visualization aesthetic"
      ],
      "avoid": [
        "cartoon",
        "bright pastels",
        "white background",
        "hand-drawn marketing illustration",
        "lifestyle / consumer photography"
      ]
    },
    "voice": {
      "tone": "Precise, technical, measured. Numbers > adjectives. Avoid marketing language.",
      "avoid": [
        "exclamation marks",
        "buzzwords (synergy, leverage, unlock)",
        "vague qualifiers (significantly, substantially)"
      ]
    },
    "surface": {
      "cornerRadius": 0.02,
      "elevation": "hairline",
      "accentStripe": {
        "position": "top",
        "widthCm": 0.12,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "4ADE80",
      "negative": "F87171",
      "warning": "FBBF24",
      "info": "60A5FA",
      "neutral": "94A3B8"
    },
    "dataviz": {
      "categorical": [
        "38BDF8",
        "4ADE80",
        "F87171",
        "FBBF24",
        "C084FC",
        "2DD4BF"
      ],
      "sequential": {
        "from": "0F2A40",
        "to": "38BDF8"
      },
      "diverging": {
        "negative": "F87171",
        "mid": "475569",
        "positive": "4ADE80"
      }
    },
    "typography": {
      "baseHalfPt": 26,
      "ratio": 1.25,
      "italicCjk": false,
      "numerals": "tabular",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "upper",
          "trackingHalfPt": 4
        }
      }
    },
    "numbering": {
      "style": "decimal"
    },
    "table": {
      "headerFill": "brand-deep",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "bold"
    },
    "image": {
      "defaultClip": "rect"
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
