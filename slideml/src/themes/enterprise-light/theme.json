{
  "name": "enterprise-light",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Enterprise Light",
  "description": "General-purpose enterprise / consulting theme — light canvas, restrained blue accents, compact cards, strong tables and executive-readable information density.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "F7F8FA",
    "bg-card": "FFFFFF",
    "brand-primary": "2563EB",
    "brand-deep": "1E3A8A",
    "text-strong": "111827",
    "text-muted": "6B7280",
    "accent": "0F766E",
    "divider": "D7DCE3",
    "font-latin": [
      "Aptos",
      "Inter",
      "Source Sans 3",
      "IBM Plex Sans",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Source Han Sans CN",
      "Microsoft YaHei",
      "Noto Sans CJK SC",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Fira Code",
      "SF Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ],
    "semantic-up": "4ADE80",
    "semantic-down": "F87171",
    "semantic-warn": "FBBF24",
    "semantic-bad": "F87171"
  },
  "meta": {
    "audiences": [
      "executives",
      "management teams",
      "consultants",
      "operators",
      "business analysts"
    ],
    "industries": [
      "consulting",
      "finance",
      "operations",
      "enterprise software",
      "strategy",
      "market research"
    ],
    "moods": [
      "serious",
      "structured",
      "neutral",
      "print-friendly",
      "executive-readable"
    ],
    "antiPatterns": [
      "cinematic product launches",
      "playful marketing",
      "editorial essays",
      "dark-stage keynotes"
    ]
  },
  "style": {
    "titleAccentRule": true,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "›",
      "color": "brand-primary"
    },
    "imagery": {
      "guidance": "Professional enterprise photography or clean data-oriented illustration. Bright, neutral backgrounds with restrained blue accents. Subjects: boardrooms, teams reviewing dashboards, market maps, operations workflows, financial charts, product screenshots, clean office environments. Avoid dramatic dark lighting, decorative gradients, cartoon mascots, and consumer-lifestyle stock-photo energy.",
      "palette": [
        "#F7F8FA",
        "#2563EB",
        "#0F766E",
        "#111827"
      ],
      "preferredStyles": [
        "photographic",
        "clean enterprise",
        "documentary business",
        "minimal data visualization",
        "neutral editorial"
      ],
      "avoid": [
        "cartoon",
        "dramatic dark lighting",
        "oversaturated gradients",
        "hand-drawn marketing illustration",
        "busy lifestyle photography"
      ]
    },
    "voice": {
      "tone": "Crisp, board-ready, evidence-led. Lead with the implication, then the support. Prefer concrete nouns, active verbs, and measured claims.",
      "avoid": [
        "exclamation marks",
        "buzzwords (synergy, leverage, unlock)",
        "vague qualifiers (significantly, substantially)"
      ]
    },
    "surface": {
      "cornerRadius": 0.02,
      "elevation": "hairline",
      "accentStripe": {
        "position": "left",
        "widthCm": 0.08,
        "color": "brand-primary"
      },
      "borderPolicy": "card-only"
    },
    "semantic": {
      "positive": "15803D",
      "negative": "DC2626",
      "warning": "D97706",
      "info": "2563EB",
      "neutral": "6B7280"
    },
    "dataviz": {
      "categorical": [
        "2563EB",
        "0F766E",
        "D97706",
        "7C3AED",
        "DC2626",
        "64748B"
      ],
      "sequential": {
        "from": "DBEAFE",
        "to": "1D4ED8"
      },
      "diverging": {
        "negative": "DC2626",
        "mid": "E5E7EB",
        "positive": "15803D"
      }
    },
    "typography": {
      "baseHalfPt": 25,
      "ratio": 1.25,
      "italicCjk": false,
      "numerals": "tabular",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "upper",
          "trackingHalfPt": 4
        }
      }
    },
    "numbering": {
      "style": "decimal"
    },
    "table": {
      "headerFill": "brand-primary",
      "rowStripe": true,
      "borderStyle": "rows",
      "firstColEmphasis": "bold"
    },
    "image": {
      "defaultClip": "rect"
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
      "accent1": "brand-primary",
      "accent2": "brand-deep",
      "accent3": "accent",
      "accent4": "text-muted",
      "accent5": "divider",
      "accent6": "bg-card",
      "hlink": "brand-primary",
      "folHlink": "brand-deep"
    },
    "fontScheme": {
      "majorLatin": "Aptos Display",
      "minorLatin": "Aptos"
    }
  },
