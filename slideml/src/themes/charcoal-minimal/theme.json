{
  "name": "charcoal-minimal",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Charcoal Minimal",
  "description": "Minimal, print-friendly theme — off-white canvas, near-black text, charcoal accents, single warm pop. No accent rules. Maximum restraint.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "F2F2F2",
    "bg-card": "FFFFFF",
    "brand-primary": "36454F",
    "brand-deep": "212121",
    "text-strong": "212121",
    "text-muted": "5A6770",
    "accent": "9B6520",
    "divider": "D9D9D9",
    "font-latin": [
      "Source Sans Pro",
      "Helvetica Neue",
      "Helvetica",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Microsoft YaHei",
      "Source Han Sans CN",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "readers (print-first)",
      "consulting / strategy clients",
      "design-conscious internal audiences",
      "B&W-photocopier-friendly distribution"
    ],
    "industries": [
      "consulting",
      "design",
      "law / professional services",
      "academia",
      "any deck that will be printed"
    ],
    "moods": [
      "minimal",
      "restrained",
      "type-driven",
      "print-friendly",
      "design-conscious"
    ],
    "antiPatterns": [
      "color-heavy data dashboards",
      "marketing pitches that need 'pop'",
      "consumer / playful",
      "tech keynotes that want flash"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "warn",
    "imagery": {
      "guidance": "B&W or near-monochrome. Heavy use of negative space. Single warm-amber accent for emphasis only. Subjects: architectural details, hands, single objects on neutral backgrounds, geometric studies, typography close-ups. Lighting: high-contrast B&W or low-key with one warm highlight. Composition: rule-of-thirds, generous margins, never busy. Avoid: color-rich illustration, photo collages, busy backgrounds, gradients.",
      "palette": [
        "#F2F2F2",
        "#212121",
        "#9B6520"
      ],
      "preferredStyles": [
        "B&W photography",
        "minimal product photography",
        "architectural detail",
        "single-object still life"
      ],
      "avoid": [
        "color-rich illustration",
        "busy backgrounds",
        "gradient overlays",
        "photo collage",
        "stock photography clichés"
      ]
    },
    "voice": {
      "tone": "Minimal. Cut every word that doesn't earn its place. Sentence fragments are fine.",
      "avoid": [
        "padding phrases",
        "rhetorical flourish",
        "exclamation marks"
      ]
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
      "accent1": "brand-primary",
      "accent2": "accent",
      "accent3": "brand-deep",
      "accent4": "text-muted",
      "accent5": "divider",
      "accent6": "bg-card",
      "hlink": "brand-primary",
      "folHlink": "accent"
    },
    "fontScheme": {
      "majorLatin": "Source Sans Pro",
      "minorLatin": "Source Sans Pro"
    }
  },
  "layouts": [
    {
      "name": "cover",
      "module": "layouts/cover.js",
      "thumbnail": "thumbnails/cover.png"
    },
    {
      "name": "agenda",
      "module": "layouts/agenda.js",
      "thumbnail": "thumbnails/agenda.png"
    },
    {
      "name": "stat-grid-3",
      "module": "layouts/stat-grid-3.js",
      "thumbnail": "thumbnails/stat-grid-3.png"
    },
    {
      "name": "chart-with-takeaway",
      "module": "layouts/chart-with-takeaway.js",
      "thumbnail": "thumbnails/chart-with-takeaway.png"
    },
    {
      "name": "bullet-with-image",
      "module": "layouts/bullet-with-image.js",
      "thumbnail": "thumbnails/bullet-with-image.png"
    },
    {
      "name": "closing",
      "module": "layouts/closing.js",
      "thumbnail": "thumbnails/closing.png"
    }
  ],
  "chrome": [
    "page-number"
  ]
}
