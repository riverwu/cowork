{
  "name": "charcoal-minimal",
  "version": "1.0.0",
  "slidemlVersion": "1",
  "displayName": "Charcoal Minimal",
  "description": "Minimal, print-friendly theme — off-white canvas, near-black text, charcoal accents, single warm pop. No accent rules. Maximum restraint.",
  "author": "SlideML",
  "tokens": {
    "bg-canvas": "F2F2F2",
    "bg-card": "FFFFFF",
    "brand-primary": "36454F",
    "brand-deep": "212121",
    "text-strong": "212121",
    "text-muted": "5A6770",
    "accent": "9B6520",
    "divider": "D9D9D9",
    "font-latin": [
      "Helvetica Neue",
      "Helvetica",
      "Inter",
      "Arial",
      "sans-serif"
    ],
    "font-cjk": [
      "PingFang SC",
      "Source Han Sans CN",
      "Microsoft YaHei",
      "Noto Sans CJK SC",
      "Noto Sans SC",
      "sans-serif"
    ],
    "font-mono": [
      "JetBrains Mono",
      "SF Mono",
      "Menlo",
      "Consolas",
      "monospace"
    ]
  },
  "meta": {
    "audiences": [
      "readers (print-first)",
      "consulting / strategy clients",
      "design-conscious internal audiences",
      "B&W-photocopier-friendly distribution"
    ],
    "industries": [
      "consulting",
      "design",
      "law / professional services",
      "academia",
      "any deck that will be printed"
    ],
    "moods": [
      "minimal",
      "restrained",
      "type-driven",
      "print-friendly",
      "design-conscious"
    ],
    "antiPatterns": [
      "color-heavy data dashboards",
      "marketing pitches that need 'pop'",
      "consumer / playful",
      "tech keynotes that want flash"
    ]
  },
  "style": {
    "titleAccentRule": false,
    "contrastTarget": "warn",
    "bullets": {
      "glyph": "·",
      "color": "text-strong"
    },
    "imagery": {
      "guidance": "B&W or near-monochrome. Heavy use of negative space. Single warm-amber accent for emphasis only. Subjects: architectural details, hands, single objects on neutral backgrounds, geometric studies, typography close-ups. Lighting: high-contrast B&W or low-key with one warm highlight. Composition: rule-of-thirds, generous margins, never busy. Avoid: color-rich illustration, photo collages, busy backgrounds, gradients.",
      "palette": [
        "#F2F2F2",
        "#212121",
        "#9B6520"
      ],
      "preferredStyles": [
        "B&W photography",
        "minimal product photography",
        "architectural detail",
        "single-object still life"
      ],
      "avoid": [
        "color-rich illustration",
        "busy backgrounds",
        "gradient overlays",
        "photo collage",
        "stock photography clichés"
      ]
    },
    "voice": {
      "tone": "Minimal. Cut every word that doesn't earn its place. Sentence fragments are fine.",
      "avoid": [
        "padding phrases",
        "rhetorical flourish",
        "exclamation marks"
      ]
    },
    "surface": {
      "cornerRadius": 0.0,
      "elevation": "flat",
      "accentStripe": {
        "position": "none",
        "widthCm": 0.08,
        "color": "brand-primary"
      },
      "borderPolicy": "none"
    },
    "semantic": {
      "positive": "4A7C59",
      "negative": "8B3A3A",
      "warning": "9C7A1F",
      "info": "4A6FA5",
      "neutral": "6B6B6B"
    },
    "dataviz": {
      "categorical": [
        "2B2B2B",
        "6B6B6B",
        "4A6FA5",
        "8B3A3A",
        "4A7C59",
        "9C7A1F"
      ],
      "sequential": {
        "from": "EFEFEF",
        "to": "2B2B2B"
      },
      "diverging": {
        "negative": "8B3A3A",
        "mid": "D6D6D6",
        "positive": "4A7C59"
      }
    },
    "typography": {
      "baseHalfPt": 26,
      "ratio": 1.2,
      "italicCjk": false,
      "numerals": "tabular",
      "roles": {
        "title": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 1
        },
        "heading": {
          "weight": "bold",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "body": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "caption": {
          "weight": "regular",
          "transform": "none",
          "trackingHalfPt": 0
        },
        "label": {
          "weight": "medium",
          "transform": "upper",
          "trackingHalfPt": 6
        }
      }
    },
    "numbering": {
      "style": "decimal"
    },
    "table": {
      "headerFill": "text-strong",
      "rowStripe": false,
      "borderStyle": "rows",
      "firstColEmphasis": "bold"
    },
    "image": {
      "defaultClip": "rect"
    }
  },
  "oxml": {
    "clrScheme": {
      "bg1": "bg-canvas",
      "tx1": "text-strong",
      "bg2": "bg-card",
      "tx2": "text-muted",
