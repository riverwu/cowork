{
  "name": "slideml",
  "version": "0.1.0",
  "description": "Typed, theme-driven YAML language that compiles to PPTX",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "slideml": "dist/bin/slideml.js"
  },
  "files": [
    "dist",
    "themes",
    "schema",
    "PLAN.md",
    "SPEC.md",
    "README.md",
    "LICENSE",
    "LICENSE-thirdparty"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-theme-assets.mjs && node dist/bin/slideml.js schema -o schema/slideml.schema.json",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:boundary": "node scripts/check-boundary.mjs",
    "render:check": "pnpm run build && node scripts/render-check.mjs",
    "conformance:audit": "node scripts/conformance-audit.mjs",
    "check": "pnpm run lint:boundary && tsc --noEmit && vitest run",
    "check:full": "pnpm run check && pnpm run conformance:audit && pnpm run render:check"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "pptx",
    "powerpoint",
    "slides",
    "yaml",
    "presentation"
  ]
}
